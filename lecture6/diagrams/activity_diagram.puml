' ================================================================================
' Diagram 3: Activity Diagram -- UC-02: Robot Completes a Task
' File: activity_complete_task.png
' ================================================================================

@startuml activity_complete_task
!theme mono
skinparam defaultFontSize 12
skinparam shadowing false

title UC-02: Robot Completes a Task

start

:Robot checks battery level against
task.duration_s * drain_rate;

if (Battery sufficient?) then (yes)
    :Robot navigates to target zone;
    :Robot picks up object at source zone;
    :Robot delivers object to target zone;

    if (Battery depleted mid-task?) then (yes)
        :task.cancel();
        note right
            Sets task.status = 'cancelled'
            Robot returns to 'active' if battery > 0
        end note
        :Evaluate battery trigger rules;
        if (battery == 0?) then (yes)
            :status = 'offline';
        elseif (battery < 10?) then (yes)
            :status = 'needs_recharge';
        else (no)
            :status = 'active';
        endif
    else (no)
        :task.complete();
        note right
            Sets task.status = 'completed'
            Triggers team.update_score(task.points)
        end note

        :robot.tasks_completed += 1;

        :Evaluate battery trigger rules;
        if (battery == 0?) then (yes)
            :status = 'offline';
        elseif (battery < 10?) then (yes)
            :status = 'needs_recharge';
        else (no)
            :status = 'active';
        endif
    endif

else (no)
    :Robot calls recharge();
    note right
        Sets battery = 100
        Sets status = 'active'
    end note

    :Robot navigates to target zone;
    :Robot picks up object at source zone;
    :Robot delivers object to target zone;

    if (Battery depleted mid-task?) then (yes)
        :task.cancel();
        note right
            Sets task.status = 'cancelled'
            Robot returns to 'active' if battery > 0
        end note
        :Evaluate battery trigger rules;
        if (battery == 0?) then (yes)
            :status = 'offline';
        elseif (battery < 10?) then (yes)
            :status = 'needs_recharge';
        else (no)
            :status = 'active';
        endif
    else (no)
        :task.complete();
        note right
            Sets task.status = 'completed'
            Triggers team.update_score(task.points)
        end note

        :robot.tasks_completed += 1;

        :Evaluate battery trigger rules;
        if (battery == 0?) then (yes)
            :status = 'offline';
        elseif (battery < 10?) then (yes)
            :status = 'needs_recharge';
        else (no)
            :status = 'active';
        endif
    endif
endif

:Postconditions evaluated;
note right
    task.status in {'completed', 'cancelled'}
    team.score updated (if completed)
    robot.status set per battery trigger rules
    robot._current_task cleared
end note

stop

@enduml